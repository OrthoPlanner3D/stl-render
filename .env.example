# Endpoint de la Cloud Function stl-to-glb
VITE_STL_ENDPOINT=https://us-central1-orthoplanner.cloudfunctions.net/stl-to-glb

# API key del endpoint (header x-api-key).
# OJO: las vars VITE_ quedan EXPUESTAS en el bundle del browser. Esto es temporal
# hasta definir la auth real (JWT de Supabase). No usar una key sensible a largo plazo.
VITE_STL_API_KEY=

# Supabase compartido con op3dcloud (para listar pacientes y vincularlos a las cargas).
# Copiar los valores del .env.local de op3dcloud.
# OJO: la SERVICE_ROLE saltea RLS y queda EXPUESTA en el bundle. Temporal, misma deuda
# que VITE_STL_API_KEY (necesaria porque op3dcloud.patients solo permite lectura a
# usuarios autenticados y este proyecto no tiene sesión Supabase real todavía).
VITE_SUPABASE_PROJECT_URL=https://fake-fake-fake-fake.supabase.co
VITE_SUPABASE_SERVICE_ROLE=
VITE_SUPABASE_SCHEMA=op3dcloud

# Bucket privado donde la Cloud Function deja los GLB por caso y desde donde el visor
# los lista/firma. Opcional: si falta, el código usa 'patient-models' por default.
VITE_SUPABASE_BUCKET=patient-models
